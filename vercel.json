{
    "builds": [
        { "src": "index.html", "use": "@vercel/static" },
        { "src": "contester-amende-sncf/**", "use": "@vercel/static" },
        { "src": "static/**", "use": "@vercel/static" },
        { "src": "api/**/*.py", "use": "@vercel/python" }
    ],
    "routes": [
        { "src": "/webhook/stripe", "dest": "/api/webhook/stripe.py" },
        { "src": "/api/(.*)", "dest": "/api/$1" },
        { "src": "/static/(.*)", "dest": "/static/$1" },
        { "src": "/contester-amende-sncf/(.*)", "dest": "/contester-amende-sncf/$1" },
        { "src": "/contester-amende-sncf", "dest": "/contester-amende-sncf/index.html" },
        { "src": "/(.*)", "dest": "/$1" }
    ]
}
